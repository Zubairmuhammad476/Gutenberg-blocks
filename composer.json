{
    "name": "zubairmuhammad476/mfd-dashboard-widget",
    "description": "Micro-Frontend Dashboard Widget — Production-grade Gutenberg block plugin for enterprise membership dashboards and client portals.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Zubair Muhammad",
            "homepage": "https://github.com/Zubairmuhammad476",
            "role": "Lead Engineer"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "*",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "MFD\\DashboardWidget\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MFD\\DashboardWidget\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpcs": "phpcs --standard=WordPress --extensions=php src/",
        "phpcbf": "phpcbf --standard=WordPress --extensions=php src/",
        "phpcs:report": "phpcs --standard=WordPress --extensions=php --report=summary src/"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "extra": {
        "wordpress-plugin-main-file": "mfd-dashboard-widget.php"
    }
}
